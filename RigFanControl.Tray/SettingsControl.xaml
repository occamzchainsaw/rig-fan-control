<UserControl x:Class="RigFanControl.Tray.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RigFanControl.Tray"
             mc:Ignorable="d"
             d:Width="360" d:Height="360"
             Width="360" Height="360">

    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Text="Select your fan header"/>
        <ListBox Grid.Row="1"
                 Margin="0,0,0,12"
                 Padding="0"
                 SelectionMode="Single"
                 HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding FanCandidates, UpdateSourceTrigger=PropertyChanged}"
                 SelectedItem="{Binding SelectedCandidate, UpdateSourceTrigger=PropertyChanged}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="">
                    <Grid ColumnDefinitions="*,Auto"
                          VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Left"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Path=Name}"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Text="{Binding Path=Id}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <CheckBox Grid.Row="2"
                  Margin="0,0,0,12"
                  Content="Start application with Windows"
                  IsChecked="{Binding StartWithWindows, UpdateSourceTrigger=PropertyChanged}"/>
        <CheckBox Grid.Row="3"
                  Margin="0,0,0,12"
                  Content="Start fan on application start"
                  IsChecked="{Binding StartFanOnStart, UpdateSourceTrigger=PropertyChanged}"/>
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelClicked"/>
            <Button Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
