<UserControl x:Class="RigFanControl.Tray.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RigFanControl.Tray"
             mc:Ignorable="d"
             d:Width="248" d:Height="360"
             Width="248" Height="360">

    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Text="Select your fan header"/>
        <ListBox Grid.Row="1"
                 Margin="0,0,0,8"
                 SelectionMode="Single"
                 ItemsSource="{Binding ViewModel.FanCandidates, UpdateSourceTrigger=PropertyChanged}"
                 SelectedItem="{Binding ViewModel.SelectedCandidate, UpdateSourceTrigger=PropertyChanged}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Path=Name}"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Text="{Binding Path=Id}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,8,0"
                    Content="Cancel"
                    Click="CancelClicked"/>
            <Button Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
