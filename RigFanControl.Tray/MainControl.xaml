<UserControl x:Class="RigFanControl.Tray.MainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RigFanControl.Tray"
             mc:Ignorable="d"
             d:DesignWidth="360" d:DesignHeight="160"
             Width="360" Height="160">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,*"
          Background="Transparent"
          MouseDown="GridMouseDown">
        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Text="Rig Fan Control"/>
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,Auto"
              VerticalAlignment="Stretch">
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding FanName, StringFormat='{}{0} speed', FallbackValue='Fan speed'}"/>
            <TextBlock Grid.Column="1"
                       Margin="0,0,12,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="{Binding FanSpeedReading, StringFormat='{}{0} RPM', FallbackValue='- RPM'}"/>
            <Button Grid.Column="2"
                    Width="36" Height="36"
                    Padding="0"
                    VerticalAlignment="Center"
                    Click="SettingsClicked">
                <Path Stretch="Uniform"
                      Width="16"
                      Height="16"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      Data="M425-80q-18.33 0-32.17-12-13.83-12-16.5-30l-13-84.67q-17-6.33-34.83-16.66-17.83-10.34-32.17-21.67l-78 35.33Q200.67-202 183-208q-17.67-6-27.67-22.33L101-327q-10-16.33-5.67-34.33 4.34-18 19.34-29.67l71-52.67q-1.67-8.33-2-18.16-.34-9.84-.34-18.17 0-8.33.34-18.17.33-9.83 2-18.16l-71-52.67q-15-11.67-19.34-29.67Q91-616.67 101-633l54.33-96.67Q165.33-746 183-752t35.33 1.67l78 35.33q14.34-11.33 32.34-21.67 18-10.33 34.66-16l13-85.33q2.67-18 16.5-30 13.84-12 32.17-12h110q18.33 0 32.17 12 13.83 12 16.5 30l13 84.67q17 6.33 35.16 16.33 18.17 10 31.84 22l78-35.33q17.66-7.67 35-1.67Q794-746 804-729.67L859-633q10 16.33 5.67 34.67Q860.33-580 845.33-569l-71 51.33q1.67 9 2 18.84.34 9.83.34 18.83 0 9-.34 18.5Q776-452 774-443l71 52q15 11 19.33 29.33 4.34 18.34-5.66 34.67L804-230.33Q794-214 776.33-208q-17.66 6-35.33-1.67L663.67-245q-14.34 11.33-32 22-17.67 10.67-35 16.33l-13 84.67q-2.67 18-16.5 30Q553.33-80 535-80H425Zm12.33-66.67h85l14-110q32.34-8 60.84-24.5T649-321l103.67 44.33 39.66-70.66L701-415q4.33-16 6.67-32.17Q710-463.33 710-480q0-16.67-2-32.83-2-16.17-7-32.17l91.33-67.67-39.66-70.66L649-638.67q-22.67-25-50.83-41.83-28.17-16.83-61.84-22.83l-13.66-110h-85l-14 110q-33 7.33-61.5 23.83T311-639l-103.67-44.33-39.66 70.66L259-545.33Q254.67-529 252.33-513 250-497 250-480q0 16.67 2.33 32.67 2.34 16 6.67 32.33l-91.33 67.67 39.66 70.66L311-321.33q23.33 23.66 51.83 40.16 28.5 16.5 60.84 24.5l13.66 110Zm43.34-200q55.33 0 94.33-39T614-480q0-55.33-39-94.33t-94.33-39q-55.67 0-94.5 39-38.84 39-38.84 94.33t38.84 94.33q38.83 39 94.5 39ZM480-480Z"/>
            </Button>
        </Grid>
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              VerticalAlignment="Stretch">
            <Slider Grid.Column="0"
                    Minimum="0" Maximum="100"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Margin="2,0,12,0"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    Value="{Binding SpeedSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Column="1"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Width="80"
                     PreviewTextInput="PreviewTextInputHandler"
                     KeyDown="SpeedTextBoxKeyDown"
                     Text="{Binding SpeedSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Column="2"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       Text="%"/>
            <Border Grid.Column="0" Grid.ColumnSpan="3"
                    Margin="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    Visibility="{Binding IncompleteConfig, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Configuration Incomplete"/>
                    <TextBlock HorizontalAlignment="Center"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Go to Settings to select your fan header"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
